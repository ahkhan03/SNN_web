---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** "narrow" (3xl) for prose, "wide" (6xl) for landing/gallery. */
  width?: "narrow" | "wide";
}

const {
  title = "snn — spiking networks as convex optimizers",
  description = "A friendly tour of the spiking-neural-network / convex-optimization equivalence, with code, math, and worked examples for students and researchers.",
  width = "wide",
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href.replace(/\/$/, ""));

const navItems = [
  { href: "/intro/", label: "Intro" },
  { href: "/tutorials/", label: "Tutorials" },
  { href: "/papers/", label: "Papers" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="px-6 sm:px-10 py-5 border-b border-[--color-rule] bg-[--color-bg]/85 backdrop-blur-md sticky top-0 z-20">
      <nav class="max-w-6xl mx-auto flex items-center justify-between gap-6">
        <a href="/" class="font-semibold text-lg no-underline text-[--color-fg] flex items-center gap-2.5 group">
          <svg width="22" height="22" viewBox="0 0 32 32" class="shrink-0">
            <path d="M16 5l4.2 4.2L24.5 16l-4.3 6.8L16 27l-4.2-4.2L7.5 16l4.3-6.8L16 5z"
                  fill="#205e96" opacity="0.18"/>
            <circle cx="16" cy="16" r="4.6" fill="#205e96"
                    class="transition-transform duration-300 group-hover:scale-125"
                    style="transform-origin: center; transform-box: fill-box"/>
          </svg>
          <span style="font-family: var(--font-display); font-variation-settings: 'opsz' 36;">
            <span class="text-[--color-accent]">snn</span><span class="text-[--color-soft]">·</span>optimization
          </span>
        </a>
        <ul class="flex items-center gap-1 sm:gap-2 text-sm" style="font-family: var(--font-sans);">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "no-underline px-3 py-1.5 rounded-md transition-colors",
                  isActive(item.href)
                    ? "text-[--color-fg] bg-[--color-paper]"
                    : "text-[--color-muted] hover:text-[--color-fg] hover:bg-[--color-paper]/60",
                ]}
              >{item.label}</a>
            </li>
          ))}
          <li class="ml-1">
            <a
              href="https://github.com/ahkhan03/SNN_opt"
              class="no-underline px-3 py-1.5 rounded-md text-[--color-muted] hover:text-[--color-fg] hover:bg-[--color-paper]/60 inline-flex items-center gap-1.5"
            >
              GitHub
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M3.5 2.5h6v6M9.5 2.5L2.5 9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 px-6 sm:px-10 py-10 sm:py-14">
      <slot />
    </main>

    <footer class="px-6 sm:px-10 py-12 border-t border-[--color-rule] text-sm text-[--color-muted] mt-12">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row gap-6 sm:items-end sm:justify-between">
        <div>
          <div class="flex items-center gap-2 mb-2 text-[--color-fg]" style="font-family: var(--font-display);">
            <svg width="16" height="16" viewBox="0 0 32 32"><circle cx="16" cy="16" r="4" fill="#205e96"/></svg>
            <span class="font-semibold">snn·optimization</span>
          </div>
          <p>© 2026 Ameer Hamza Khan · School of AI, Taizhou University</p>
          <p class="text-xs mt-1 text-[--color-soft]">A friendly companion to the <code class="text-[--color-soft]">snn_opt</code> Python library.</p>
        </div>
        <div class="flex flex-col sm:items-end gap-2" style="font-family: var(--font-sans);">
          <div class="flex gap-5 text-xs uppercase tracking-widest">
            <a href="https://github.com/ahkhan03/SNN_opt" class="no-underline">repository</a>
            <a href="/papers/" class="no-underline">papers</a>
            <a href="https://ahkhan.me" class="no-underline">ahkhan.me</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
